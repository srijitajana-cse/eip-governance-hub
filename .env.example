# Copy this file to .env.local and fill in what you have.
# Every value is optional — anything left unset falls back to mock data
# so the app runs fully offline out of the box.

# --- 3.1 Governance Assistant --------------------------------------
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# --- 3.2 PR Review Summarizer ---------------------------------------
# Fine-grained personal access token with read access to pull requests
# on the target repo (e.g. ethereum/EIPs). https://github.com/settings/tokens
GITHUB_TOKEN=

# --- 3.3 Notification Hub -------------------------------------------
# Create a bot with @BotFather on Telegram to get a token.
TELEGRAM_BOT_TOKEN=
